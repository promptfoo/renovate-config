{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard",
    "customManagers:biomeVersions",
    "helpers:pinGitHubActionDigests"
  ],
  "rangeStrategy": "replace",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on Sunday"]
  },
  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Pin @biomejs/biome so the installed package stays aligned with biome.json schema updates",
      "matchManagers": ["npm"],
      "matchPackageNames": ["@biomejs/biome"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Group Biome package with biome.json schema updates",
      "matchPackageNames": ["@biomejs/biome"],
      "groupName": "biome"
    },
    {
      "description": "Group React packages to keep versions in sync",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "react monorepo"
    },
    {
      "description": "Update GitHub Actions monthly",
      "matchManagers": ["github-actions"],
      "schedule": ["monthly"]
    },
    {
      "description": "Limit lucide-react updates to bi-weekly schedule (icon library with excessive release frequency)",
      "matchPackageNames": ["lucide-react"],
      "schedule": ["every 2 weeks on Sunday"]
    },
    {
      "description": "Let GitHub Action digest updates settle briefly before opening PRs",
      "matchManagers": ["github-actions"],
      "matchDepTypes": ["action"],
      "minimumReleaseAge": "3 days"
    }
  ]
}
